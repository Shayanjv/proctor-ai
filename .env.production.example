# =============================================================================
# Production environment template
# -----------------------------------------------------------------------------
# Copy this to `.env` on the Droplet:
#     cp .env.production.example .env
# Then edit the placeholders (CHANGE_ME, your IP). Never commit `.env`.
#
# Used by `docker-compose.prod.yml`.
# =============================================================================

# -----------------------------------------------------------------------------
# Public hostname - DERIVED FROM YOUR DROPLET IP
#
# nip.io maps any IP-embedded hostname to that IP for free.
# Take your Droplet's public IPv4 (e.g. 167.99.45.12) and replace the dots
# with dashes:
#     PUBLIC_HOST=167-99-45-12.nip.io
# (Dot form `167.99.45.12.nip.io` also works but Let's Encrypt prefers the
# dashed form because it counts as a single label.)
#
# After editing this, three URLs are live (once Caddy gets its certs):
#     https://${PUBLIC_HOST}            -> student
#     https://admin.${PUBLIC_HOST}      -> admin
#     https://api.${PUBLIC_HOST}        -> backend API + WS
# -----------------------------------------------------------------------------
PUBLIC_HOST=CHANGE-ME-TO-DROPLET-IP.nip.io

# Used as the ACME account contact for Let's Encrypt notifications
# (cert-expiry reminders, abuse notices). Any real mailbox works.
LETSENCRYPT_EMAIL=you@example.com

# -----------------------------------------------------------------------------
# Postgres
# -----------------------------------------------------------------------------
POSTGRES_USER=proctor
# Run `openssl rand -base64 24` on the Droplet to generate a strong one.
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=proctoring_db

# -----------------------------------------------------------------------------
# Backend auth
# -----------------------------------------------------------------------------
# `openssl rand -hex 32` for a 64-char hex secret.
JWT_SECRET_KEY=CHANGE_ME_LONG_RANDOM_HEX_STRING

# Pydantic Settings sometimes also reads these. Keep them aligned with
# JWT_SECRET_KEY unless you understand what splits them.
SECRET_KEY=CHANGE_ME_LONG_RANDOM_HEX_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# -----------------------------------------------------------------------------
# MinIO (S3-compatible storage for evidence frames)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_MINIO_PASSWORD
MINIO_BUCKET_NAME=evidence-bucket

# -----------------------------------------------------------------------------
# Backend tuning
# -----------------------------------------------------------------------------
# Single worker is the safe default for the ML stack (PyTorch + TF + DeepFace
# do not survive gunicorn fork-after-init). Raise to 2 only on a >= 8GB Droplet.
WEB_CONCURRENCY=1
GUNICORN_TIMEOUT=0

# -----------------------------------------------------------------------------
# Seed accounts (created on first boot if the table is empty)
# -----------------------------------------------------------------------------
SEED_DEFAULT_USERS=true
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
